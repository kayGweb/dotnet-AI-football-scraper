@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">NFL WebScraper Admin</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mr-3">@context.User.Identity?.Name</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                               Color="Color.Inherit"
                               Href="/admin/logout"
                               Title="Logout" />
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always">
        <MudNavMenu>
            <MudNavLink Href="/admin" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="/admin/jobs" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Work">Jobs</MudNavLink>
            <MudNavLink Href="/admin/scrapes/new" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.PlayArrow">New Scrape</MudNavLink>

            <AuthorizeView Roles="Admin">
                <MudDivider Class="my-2" />
                <MudNavGroup Title="Admin" Icon="@Icons.Material.Filled.AdminPanelSettings" Expanded="true">
                    <MudNavLink Href="/admin/api-keys" Icon="@Icons.Material.Filled.Key">API Keys</MudNavLink>
                    <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.People">Users</MudNavLink>
                    <MudNavLink Href="/admin/deleted-items" Icon="@Icons.Material.Filled.DeleteSweep">Deleted Items</MudNavLink>
                </MudNavGroup>
            </AuthorizeView>

            <MudDivider Class="my-2" />
            <MudNavLink Href="/admin/api-usage" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Analytics">API Usage</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
