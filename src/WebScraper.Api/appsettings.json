{
  "DatabaseProvider": "Sqlite",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=data/nfl_data.db"
  },
  "ScraperSettings": {
    "RequestDelayMs": 1500,
    "MaxRetries": 3,
    "UserAgent": "WebScraper.Api/1.0",
    "TimeoutSeconds": 30,
    "DataProvider": "Espn",
    "Providers": {
      "Espn": {
        "BaseUrl": "https://site.api.espn.com/apis/site/v2/sports/football/nfl",
        "AuthType": "None",
        "RequestDelayMs": 1200
      }
    }
  },
  "ApiKeys": {
    "Keys": [
      {
        "_comment": "Replace HashedKey with the SHA-256 hex (lowercase) of the real key — never store the plain key.",
        "Id": "local-dev",
        "Name": "Local Development",
        "HashedKey": "REPLACE_WITH_SHA256_HEX",
        "Scopes": [ "read" ]
      }
    ]
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/webscraper-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  }
}
